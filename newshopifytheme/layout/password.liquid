<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link rel="canonical" href="{{ canonical_url }}">
    {%- if settings.favicon != blank -%}<link rel="icon" href="{{ settings.favicon | image_url: width: 32 }}">{%- endif -%}
    <title>{{ shop.name }}</title>
    {{ content_for_header }}
    <style>
      :root {
        --ink: {{ settings.color_bg }}; --ink-1: {{ settings.color_surface }}; --ink-2: {{ settings.color_card }};
        --hair: {{ settings.color_hairline }}; --bone: {{ settings.color_text }}; --red: {{ settings.color_accent }};
        --red-deep: {{ settings.color_accent | color_darken: 12 }}; --gold: {{ settings.color_gold }}; --page: 1320px;
      }
    </style>
    {{ 'base.css' | asset_url | stylesheet_tag }}
  </head>
  <body class="template-password">
    <main>{{ content_for_layout }}</main>
  </body>
</html>
