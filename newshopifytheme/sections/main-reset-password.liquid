<div class="wrap auth">
  <h1>{{ 'customer.recover.title' | t }}</h1>
  <p class="sub">Choose a new password for your account.</p>
  {%- form 'reset_customer_password' -%}
    {%- if form.errors -%}<div class="form-errors">{{ form.errors | default_errors }}</div>{%- endif -%}
    <div class="field-group">
      <div><label for="reset-pass">New password</label><input type="password" id="reset-pass" name="customer[password]" required></div>
      <div><label for="reset-conf">Confirm password</label><input type="password" id="reset-conf" name="customer[password_confirmation]" required></div>
      <button type="submit" class="btn btn--primary btn--block">Reset password</button>
    </div>
  {%- endform -%}
</div>

{% schema %}
{ "name": "Reset password" }
{% endschema %}
