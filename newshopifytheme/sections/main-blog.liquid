{%- paginate blog.articles by 12 -%}
<style>
  .blog-head { padding-block: clamp(24px, 4vw, 44px); }
  .blog-title { font-family: var(--f-display); font-weight: 800; font-stretch: condensed; text-transform: uppercase; font-size: clamp(34px, 6vw, 64px); margin: 0; line-height: .9; }
  .article-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--gap); }
  .article-card { border: 1px solid var(--hair); border-radius: var(--radius); overflow: hidden; background: var(--ink-1); transition: border-color .16s, transform .16s; }
  .article-card:hover { border-color: var(--red); transform: translateY(-3px); }
  .article-card .thumb { aspect-ratio: 16/10; background: var(--ink-2); overflow: hidden; }
  .article-card .thumb img { width: 100%; height: 100%; object-fit: cover; }
  .article-card .body { padding: 16px 16px 20px; }
  .article-card time { font-family: var(--f-mono); font-size: 11px; color: var(--red); letter-spacing: .08em; text-transform: uppercase; }
  .article-card h2 { font-size: 18px; margin: 8px 0 8px; line-height: 1.2; }
  .article-card p { color: var(--muted); font-size: 14px; margin: 0; }
  @media (max-width: 860px) { .article-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 540px) { .article-grid { grid-template-columns: 1fr; } }
</style>
<div class="wrap blog-head">
  <span class="eyebrow">From the studio</span>
  <h1 class="blog-title">{{ blog.title }}</h1>
</div>
<div class="wrap section" style="padding-top:0;">
  <div class="article-grid">
    {%- for article in blog.articles -%}
      <a class="article-card" href="{{ article.url }}">
        {%- if article.image -%}<div class="thumb"><img src="{{ article.image | image_url: width: 600 }}" alt="{{ article.title | escape }}" loading="lazy"></div>{%- endif -%}
        <div class="body">
          <time datetime="{{ article.published_at | date: '%Y-%m-%d' }}">{{ article.published_at | date: '%b %d, %Y' }}</time>
          <h2>{{ article.title }}</h2>
          <p>{{ article.excerpt_or_content | strip_html | truncatewords: 22 }}</p>
        </div>
      </a>
    {%- endfor -%}
  </div>
</div>
{%- endpaginate -%}

{% schema %}
{ "name": "Blog" }
{% endschema %}
