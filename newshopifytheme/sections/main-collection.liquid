{%- comment -%} 50 is Shopify's max per page — an issue never has more covers than that, so all covers show on one page with no pagination. {%- endcomment -%}
{%- paginate collection.products by 50 -%}
<style>
  .coll-head { padding-block: clamp(24px, 4vw, 44px) 0; }
  .coll-head .eyebrow { margin-bottom: .7rem; }
  .coll-title { font-family: var(--f-display); font-weight: 800; font-stretch: condensed; text-transform: uppercase; font-size: clamp(34px, 6vw, 68px); line-height: .9; margin: 0; }
  .coll-desc { color: var(--muted); max-width: 60ch; margin: 14px 0 0; }
  .coll-toolbar {
    display: flex; align-items: center; justify-content: space-between; gap: 16px; flex-wrap: wrap;
    margin: 22px 0 24px; padding-bottom: 16px; border-bottom: 1px solid var(--hair);
  }
  .coll-count { font-family: var(--f-mono); font-size: 12px; letter-spacing: .06em; color: var(--muted); text-transform: uppercase; }
  .sort { display: inline-flex; align-items: center; gap: 8px; }
  .sort label { font-family: var(--f-mono); font-size: 11px; letter-spacing: .12em; text-transform: uppercase; color: var(--faint); }
  .sort select {
    background: var(--ink-1); border: 1px solid var(--hair); border-radius: var(--radius); color: var(--bone);
    font-family: var(--f-mono); font-size: 12.5px; padding: 8px 10px;
  }
  .pagination { display: flex; justify-content: center; gap: 6px; margin-top: clamp(32px, 5vw, 52px); }
  .pagination a, .pagination span {
    font-family: var(--f-mono); font-size: 13px; min-width: 40px; height: 40px; display: inline-flex; align-items: center; justify-content: center;
    border: 1px solid var(--hair); border-radius: var(--radius); color: var(--bone);
  }
  .pagination .current { background: var(--red); border-color: var(--red); color: #fff; }
  .empty-state { text-align: center; padding: 60px 0; color: var(--muted); }
</style>

<div class="wrap coll-head">
  <span class="eyebrow">{{ collection.products_count | default: collection.all_products_count }} items · {{ shop.name }}</span>
  <h1 class="coll-title">{{ collection.title }}</h1>
  {%- if collection.description != blank -%}<div class="coll-desc rte">{{ collection.description }}</div>{%- endif -%}
</div>

<div class="wrap">
  <div class="coll-toolbar">
    <span class="coll-count">{{ 'products.facets.results' | t: count: collection.products_count | default: collection.all_products_count }}</span>
    <form class="sort" method="get">
      <label for="SortBy">{{ 'products.facets.sort_by' | t }}</label>
      <select id="SortBy" name="sort_by" onchange="this.form.submit()">
        {%- assign current_sort = collection.sort_by | default: collection.default_sort_by -%}
        {%- for opt in collection.sort_options -%}
          <option value="{{ opt.value }}" {% if opt.value == current_sort %}selected{% endif %}>{{ opt.name }}</option>
        {%- endfor -%}
      </select>
    </form>
  </div>

  {%- if collection.products.size > 0 -%}
    <div class="cover-grid">
      {%- for product in collection.products -%}
        {% render 'product-card', product: product %}
      {%- endfor -%}
    </div>

    {%- if paginate.pages > 1 -%}
      <nav class="pagination" aria-label="Pagination">
        {%- if paginate.previous -%}<a href="{{ paginate.previous.url }}" aria-label="{{ 'accessibility.previous' | t }}">‹</a>{%- endif -%}
        {%- for part in paginate.parts -%}
          {%- if part.is_link -%}<a href="{{ part.url }}">{{ part.title }}</a>
          {%- else -%}<span class="{% if part.title == paginate.current_page %}current{% endif %}">{{ part.title }}</span>{%- endif -%}
        {%- endfor -%}
        {%- if paginate.next -%}<a href="{{ paginate.next.url }}" aria-label="{{ 'accessibility.next' | t }}">›</a>{%- endif -%}
      </nav>
    {%- endif -%}
  {%- else -%}
    <p class="empty-state">Nothing here yet — check back after the next drop.</p>
  {%- endif -%}
</div>
{%- endpaginate -%}

{% schema %}
{ "name": "Collection page" }
{% endschema %}
