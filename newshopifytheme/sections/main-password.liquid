<style>
  .pw { min-height: 100vh; display: grid; place-items: center; padding: 40px 20px; text-align: center;
    background: radial-gradient(120% 100% at 50% 0%, color-mix(in srgb, var(--red) 16%, transparent), transparent 60%), var(--ink); }
  .pw .logo { font-family: var(--f-display); font-weight: 800; font-stretch: condensed; text-transform: uppercase; font-size: clamp(48px, 12vw, 120px); line-height: .85; color: var(--bone); }
  .pw .logo b { color: var(--red); }
  .pw p { color: var(--muted); max-width: 46ch; margin: 14px auto 28px; }
  .pw form { display: flex; gap: 10px; max-width: 420px; margin: 0 auto; }
  .pw input { flex: 1; background: var(--ink-1); border: 1px solid var(--hair); border-radius: var(--radius); color: var(--bone); padding: 14px; font-family: var(--f-mono); }
  .pw .errors { color: var(--red); font-family: var(--f-mono); font-size: 13px; margin-top: 14px; }
  .pw .foot { margin-top: 40px; font-family: var(--f-mono); font-size: 11px; letter-spacing: .1em; text-transform: uppercase; color: var(--faint); }
</style>
<div class="pw">
  <div>
    <div class="logo">{{ settings.logo_text | default: shop.name }}<b>.</b></div>
    <p>{{ page_description | default: "We're stocking the shelves. Enter the password to take a look." }}</p>
    {%- form 'storefront_password' -%}
      <input type="password" name="password" placeholder="Password" aria-label="Password" required>
      <button type="submit" class="btn btn--primary">Enter</button>
    {%- endform -%}
    {%- if form.errors -%}<p class="errors">{{ form.errors | default_errors }}</p>{%- endif -%}
    <p class="foot">Powered by {{ shop.name }} · Are you the owner? <a href="/admin" style="color:var(--muted);text-decoration:underline;">Log in</a></p>
  </div>
</div>

{% schema %}
{ "name": "Password" }
{% endschema %}
