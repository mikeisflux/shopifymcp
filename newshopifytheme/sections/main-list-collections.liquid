<style>
  .list-head { padding-block: clamp(24px, 4vw, 44px); }
  .list-title { font-family: var(--f-display); font-weight: 800; font-stretch: condensed; text-transform: uppercase; font-size: clamp(34px, 6vw, 68px); line-height: .9; margin: 0; }
  .coll-list { display: grid; grid-template-columns: repeat(4, 1fr); gap: var(--gap); }
  .coll-cell {
    position: relative; aspect-ratio: 3/4; border-radius: var(--radius); overflow: hidden;
    border: 1px solid var(--hair); background: var(--ink-2); transition: border-color .16s, transform .16s;
  }
  .coll-cell:hover { border-color: var(--red); transform: translateY(-3px); }
  .coll-cell img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; opacity: .8; transition: transform .4s, opacity .2s; }
  .coll-cell:hover img { transform: scale(1.05); opacity: 1; }
  .coll-cell::after { content: ""; position: absolute; inset: 0; background: linear-gradient(to top, rgba(10,8,7,.9), transparent 55%); }
  .coll-cell .cap { position: absolute; inset: auto 0 0 0; z-index: 2; padding: 14px; }
  .coll-cell h3 { font-family: var(--f-display); font-weight: 800; font-stretch: condensed; text-transform: uppercase; font-size: 18px; margin: 0; color: #fff; line-height: .95; }
  .coll-cell span { font-family: var(--f-mono); font-size: 10px; letter-spacing: .1em; text-transform: uppercase; color: var(--muted); }
  @media (max-width: 900px) { .coll-list { grid-template-columns: repeat(3, 1fr); } }
  @media (max-width: 560px) { .coll-list { grid-template-columns: repeat(2, 1fr); } }
</style>

<div class="wrap list-head">
  <span class="eyebrow">{{ collections.size }} shelves</span>
  <h1 class="list-title">{{ page_title | default: 'All collections' }}</h1>
</div>

<div class="wrap section" style="padding-top:0;">
  <div class="coll-list">
    {%- for coll in collections -%}
      {%- liquid
        assign img = coll.image
        if img == blank and coll.products.first.featured_media != blank
          assign img = coll.products.first.featured_media
        endif
      -%}
      <a class="coll-cell" href="{{ coll.url }}">
        {%- if img != blank -%}<img src="{{ img | image_url: width: 400 }}" alt="{{ coll.title | escape }}" loading="lazy">{%- endif -%}
        <div class="cap">
          <h3>{{ coll.title }}</h3>
          <span>{{ coll.all_products_count }} items</span>
        </div>
      </a>
    {%- endfor -%}
  </div>
</div>

{% schema %}
{ "name": "Collections list" }
{% endschema %}
