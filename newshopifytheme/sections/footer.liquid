<style>
  .site-footer { background: var(--ink-1); border-top: 1px solid var(--hair); margin-top: 40px; }
  .footer-top {
    display: grid; grid-template-columns: 1.6fr repeat(3, 1fr); gap: 40px 30px;
    padding-block: clamp(40px, 6vw, 64px);
  }
  .footer-brand .logo {
    font-family: var(--f-display); font-weight: 800; font-stretch: condensed; font-size: 34px;
    text-transform: uppercase; color: var(--bone); line-height: 1;
  }
  .footer-brand .logo b { color: var(--red); }
  .footer-brand p { color: var(--muted); max-width: 34ch; margin: 14px 0 18px; font-size: 14px; }
  .footer-social { display: flex; gap: 8px; }
  .footer-social a {
    width: 38px; height: 38px; border: 1px solid var(--hair); border-radius: var(--radius);
    display: inline-flex; align-items: center; justify-content: center; color: var(--bone); transition: all .15s;
  }
  .footer-social a:hover { border-color: var(--red); color: var(--red); }
  .footer-social svg { width: 18px; height: 18px; }
  .footer-col h3 {
    font-family: var(--f-mono); font-size: 11px; letter-spacing: .18em; text-transform: uppercase;
    color: var(--faint); margin: 0 0 14px;
  }
  .footer-col ul { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 9px; }
  .footer-col a { color: var(--muted); font-size: 14px; transition: color .15s; }
  .footer-col a:hover { color: var(--bone); }
  .footer-bar {
    border-top: 1px solid var(--hair); padding-block: 18px;
    display: flex; flex-wrap: wrap; gap: 8px 20px; justify-content: space-between; align-items: center;
    font-family: var(--f-mono); font-size: 11.5px; color: var(--faint); letter-spacing: .04em;
  }
  .footer-bar .icons { display: flex; gap: 6px; align-items: center; }
  @media (max-width: 800px) { .footer-top { grid-template-columns: 1fr 1fr; } .footer-brand { grid-column: 1 / -1; } }
</style>

<footer class="site-footer">
  <div class="wrap footer-top">
    <div class="footer-brand">
      <div class="logo">{{ settings.logo_text | default: shop.name }}<b>.</b></div>
      <p>{{ section.settings.blurb }}</p>
      <div class="footer-social">
        {%- if settings.social_instagram != blank -%}<a href="{{ settings.social_instagram }}" aria-label="Instagram"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg></a>{%- endif -%}
        {%- if settings.social_x != blank -%}<a href="{{ settings.social_x }}" aria-label="X"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M18 3h3l-7 8 8 10h-6l-5-6-5 6H2l8-9L2 3h6l4 5 6-5z"/></svg></a>{%- endif -%}
        {%- if settings.social_youtube != blank -%}<a href="{{ settings.social_youtube }}" aria-label="YouTube"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="5" width="20" height="14" rx="4"/><path d="M10 9l5 3-5 3V9z" fill="currentColor"/></svg></a>{%- endif -%}
        {%- if settings.social_facebook != blank -%}<a href="{{ settings.social_facebook }}" aria-label="Facebook"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M14 8h3V5h-3c-2 0-3 1-3 3v2H9v3h2v6h3v-6h2.5l.5-3H14V8z"/></svg></a>{%- endif -%}
      </div>
    </div>

    {%- for block in section.blocks -%}
      <div class="footer-col" {{ block.shopify_attributes }}>
        <h3>{{ block.settings.title }}</h3>
        <ul>
          {%- for link in linklists[block.settings.menu].links -%}
            <li><a href="{{ link.url }}">{{ link.title }}</a></li>
          {%- endfor -%}
        </ul>
      </div>
    {%- endfor -%}
  </div>

  <div class="wrap footer-bar">
    <span>© {{ 'now' | date: '%Y' }} {{ shop.name }}. All covers © their respective artists.</span>
    <span class="icons">Ships worldwide · {{ shop.currency }}</span>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    { "type": "textarea", "id": "blurb", "label": "Brand blurb", "default": "Independent comics with more variant covers than shelf space. Books, prints, digitals and collectibles — straight from the studio." }
  ],
  "blocks": [
    {
      "type": "menu",
      "name": "Menu column",
      "settings": [
        { "type": "text", "id": "title", "label": "Heading", "default": "Shop" },
        { "type": "link_list", "id": "menu", "label": "Menu", "default": "footer" }
      ]
    }
  ],
  "default": {
    "blocks": [
      { "type": "menu", "settings": { "title": "Shop" } },
      { "type": "menu", "settings": { "title": "Series" } },
      { "type": "menu", "settings": { "title": "Help" } }
    ]
  }
}
{% endschema %}
