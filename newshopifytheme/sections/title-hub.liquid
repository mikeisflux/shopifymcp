{%- comment -%}
  Title hub — the on-brand replacement for the old "Options" page.
  Assign this section's template (page.title) to every title page.

  AUTO MODE (default): resolves each title's format collections by direct
  handle lookup from the PAGE HANDLE, e.g. page "dead-sexy-1" →
    dead-sexy-1-books / -prints / -digital (or -digitals) / -merch.
  Only the formats that actually exist (and have products) show up, so one
  template serves every title with no per-page setup.

  MANUAL MODE: turn off "Auto-detect" and add Format blocks by hand.
{%- endcomment -%}
{%- liquid
  assign h = page.handle
  assign auto = section.settings.auto_from_handle

  assign c_books = false
  assign c_prints = false
  assign c_digital = false
  assign c_merch = false

  if auto and h != blank
    assign hb = h | append: '-books'
    assign t = collections[hb]
    unless t == empty
      assign c_books = t
    endunless
    unless c_books
      assign hb = h | append: '-book'
      assign t = collections[hb]
      unless t == empty
        assign c_books = t
      endunless
    endunless

    assign hp = h | append: '-prints'
    assign t = collections[hp]
    unless t == empty
      assign c_prints = t
    endunless
    unless c_prints
      assign hp = h | append: '-print'
      assign t = collections[hp]
      unless t == empty
        assign c_prints = t
      endunless
    endunless

    assign hd = h | append: '-digital'
    assign t = collections[hd]
    unless t == empty
      assign c_digital = t
    endunless
    unless c_digital
      assign hd = h | append: '-digitals'
      assign t = collections[hd]
      unless t == empty
        assign c_digital = t
      endunless
    endunless

    assign hm = h | append: '-merch'
    assign t = collections[hm]
    unless t == empty
      assign c_merch = t
    endunless
  endif

  assign feat = collections[section.settings.featured_collection]
  if feat == empty
    if c_books and c_books.all_products_count > 0
      assign feat = c_books
    elsif c_prints and c_prints.all_products_count > 0
      assign feat = c_prints
    endif
  endif
  if feat == empty or feat.products.size == 0
    for block in section.blocks
      assign cb = collections[block.settings.collection]
      if cb != empty and cb.products.size > 0
        assign feat = cb
        break
      endif
    endfor
  endif
-%}
<style>
  .hub { position: relative; overflow: hidden; border-bottom: 1px solid var(--hair); }
  .hub-bg { position: absolute; inset: 0; z-index: 0; }
  .hub-bg img { width: 100%; height: 100%; object-fit: cover; opacity: .3; filter: saturate(1.1); }
  .hub-bg::after { content: ""; position: absolute; inset: 0; background: linear-gradient(to bottom, color-mix(in srgb, var(--ink) 52%, transparent), var(--ink) 88%); }
  .hub-inner { position: relative; z-index: 1; padding-block: clamp(40px, 7vw, 88px) clamp(28px, 4vw, 44px); text-align: center; }
  .hub .eyebrow { justify-content: center; }
  .hub h1 { font-family: var(--f-display); font-weight: 800; font-stretch: condensed; text-transform: uppercase; font-size: clamp(44px, 9vw, 108px); line-height: .86; letter-spacing: -.015em; margin: 8px 0 0; text-wrap: balance; }
  .hub .blurb { color: var(--muted); max-width: 56ch; margin: 16px auto 0; }

  .hub-formats { display: flex; flex-wrap: wrap; justify-content: center; gap: 10px; margin-top: 30px; }
  .format-chip {
    display: inline-flex; align-items: center; gap: 9px; padding: 12px 20px; border-radius: 999px;
    border: 1px solid var(--hair); background: color-mix(in srgb, var(--ink-1) 82%, transparent);
    font-family: var(--f-mono); font-size: 13px; letter-spacing: .08em; text-transform: uppercase; color: var(--bone);
    transition: border-color .15s, background .15s, transform .12s;
  }
  .format-chip:hover { border-color: var(--red); background: var(--ink-1); transform: translateY(-2px); }
  .format-chip .ic { color: var(--red); display: inline-flex; } .format-chip .ic svg { width: 16px; height: 16px; }
  .format-chip .n { font-family: var(--f-mono); font-size: 11px; color: var(--faint); }

  .hub-strip { padding-block: clamp(30px, 5vw, 56px); }
  .hub-strip .section-head h2 { font-size: clamp(20px, 3vw, 30px); }
  .hub-empty { text-align: center; color: var(--muted); padding: 30px 0 60px; }
</style>

{%- capture chip_books -%}{%- if c_books and c_books.all_products_count > 0 -%}<a class="format-chip" href="{{ c_books.url }}"><span class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 5a2 2 0 0 1 2-2h13v16H6a2 2 0 0 0-2 2z"/><path d="M19 3v18"/></svg></span>Books<span class="n">{{ c_books.all_products_count }}</span></a>{%- endif -%}{%- endcapture -%}
{%- capture chip_prints -%}{%- if c_prints and c_prints.all_products_count > 0 -%}<a class="format-chip" href="{{ c_prints.url }}"><span class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="4" y="4" width="16" height="13" rx="2"/><path d="m8 12 3-3 5 5"/></svg></span>Prints<span class="n">{{ c_prints.all_products_count }}</span></a>{%- endif -%}{%- endcapture -%}
{%- capture chip_digital -%}{%- if c_digital and c_digital.all_products_count > 0 -%}<a class="format-chip" href="{{ c_digital.url }}"><span class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="12" rx="2"/><path d="M8 20h8M12 16v4"/></svg></span>Digital<span class="n">{{ c_digital.all_products_count }}</span></a>{%- endif -%}{%- endcapture -%}
{%- capture chip_merch -%}{%- if c_merch and c_merch.all_products_count > 0 -%}<a class="format-chip" href="{{ c_merch.url }}"><span class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 7 4 9l3 2v9h10v-9l3-2-2-2-4-2a3 3 0 0 1-6 0z"/></svg></span>Merch<span class="n">{{ c_merch.all_products_count }}</span></a>{%- endif -%}{%- endcapture -%}

<section class="hub">
  {%- if section.settings.art_image != blank -%}
    <div class="hub-bg"><img src="{{ section.settings.art_image | image_url: width: 1800 }}" alt="" loading="eager"></div>
  {%- elsif feat != empty and feat.products.first.featured_media != blank -%}
    <div class="hub-bg"><img src="{{ feat.products.first.featured_media | image_url: width: 1800 }}" alt="" loading="eager"></div>
  {%- endif -%}
  <div class="wrap hub-inner">
    <span class="eyebrow">{{ section.settings.eyebrow | default: 'Pick your format' }}</span>
    <h1>{{ section.settings.title | default: page.title }}</h1>
    {%- if section.settings.blurb != blank -%}<p class="blurb">{{ section.settings.blurb }}</p>{%- elsif page.content != blank -%}<div class="blurb rte">{{ page.content }}</div>{%- endif -%}

    <div class="hub-formats">
      {%- if auto -%}{{ chip_books }}{{ chip_prints }}{{ chip_digital }}{{ chip_merch }}{%- endif -%}
      {%- for block in section.blocks -%}
        {%- liquid
          assign cb = collections[block.settings.collection]
          assign url = block.settings.link
          if url == blank and cb != empty
            assign url = cb.url
          endif
        -%}
        <a class="format-chip" href="{{ url | default: '#' }}" {{ block.shopify_attributes }}>
          <span class="ic">
            {%- case block.settings.icon -%}
              {%- when 'book' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 5a2 2 0 0 1 2-2h13v16H6a2 2 0 0 0-2 2z"/><path d="M19 3v18"/></svg>
              {%- when 'print' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="4" y="4" width="16" height="13" rx="2"/><path d="m8 12 3-3 5 5"/></svg>
              {%- when 'digital' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="12" rx="2"/><path d="M8 20h8M12 16v4"/></svg>
              {%- when 'merch' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 7 4 9l3 2v9h10v-9l3-2-2-2-4-2a3 3 0 0 1-6 0z"/></svg>
              {%- else -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 6h16M4 12h16M4 18h16"/></svg>
            {%- endcase -%}
          </span>
          {{ block.settings.label }}
          {%- if cb != empty and cb.all_products_count > 0 -%}<span class="n">{{ cb.all_products_count }}</span>{%- endif -%}
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

{%- if feat != empty and feat.products.size > 0 -%}
  <section class="hub-strip"><div class="wrap">
    <div class="section-head">
      <div><span class="eyebrow">In this title</span><h2>{{ section.settings.strip_heading | default: 'Latest covers' }}</h2></div>
      <a class="link-more" href="{{ feat.url }}">See all {{ feat.all_products_count }} →</a>
    </div>
    <div class="cover-grid">
      {%- for product in feat.products limit: section.settings.strip_count -%}
        {% render 'product-card', product: product %}
      {%- endfor -%}
    </div>
  </div></section>
{%- else -%}
  <p class="hub-empty">Nothing here yet — check back after the next drop.</p>
{%- endif -%}

{% schema %}
{
  "name": "Title hub",
  "settings": [
    { "type": "checkbox", "id": "auto_from_handle", "label": "Auto-detect formats from page handle", "default": true, "info": "Looks up Books/Prints/Digital/Merch collections from the page handle (e.g. dead-sexy-1 → dead-sexy-1-books). Turn off to set them manually below." },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Pick your format" },
    { "type": "text", "id": "title", "label": "Title (defaults to page title)" },
    { "type": "textarea", "id": "blurb", "label": "Blurb (defaults to page content)" },
    { "type": "image_picker", "id": "art_image", "label": "Background art (optional)" },
    { "type": "header", "content": "Cover strip" },
    { "type": "collection", "id": "featured_collection", "label": "Featured collection (optional; auto-uses Books)" },
    { "type": "text", "id": "strip_heading", "label": "Strip heading", "default": "Latest covers" },
    { "type": "range", "id": "strip_count", "label": "Covers to show", "min": 4, "max": 16, "step": 2, "default": 8 }
  ],
  "blocks": [
    {
      "type": "format",
      "name": "Format (manual)",
      "settings": [
        { "type": "text", "id": "label", "label": "Label", "default": "Books" },
        { "type": "select", "id": "icon", "label": "Icon", "default": "book",
          "options": [
            { "value": "book", "label": "Books" },
            { "value": "print", "label": "Prints" },
            { "value": "digital", "label": "Digital" },
            { "value": "merch", "label": "Merch" },
            { "value": "other", "label": "Other" }
          ]
        },
        { "type": "collection", "id": "collection", "label": "Collection" },
        { "type": "url", "id": "link", "label": "Custom link (optional, overrides collection)" }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [{ "name": "Title hub" }]
}
{% endschema %}
