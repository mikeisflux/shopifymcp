{%- liquid
  assign coll = collections[section.settings.collection]
-%}
<style>
  .hero { border-bottom: 1px solid var(--hair); overflow: hidden; }
  .hero-grid {
    display: grid; grid-template-columns: 1.05fr .95fr; align-items: center; gap: clamp(24px, 5vw, 56px);
    padding-block: clamp(34px, 5vw, 60px);
  }
  .hero-copy .eyebrow { margin-bottom: 1rem; }
  .hero-title {
    font-family: var(--f-display); font-weight: 800; font-stretch: condensed; text-transform: uppercase;
    line-height: .86; letter-spacing: -.015em; margin: 0;
    font-size: clamp(46px, 8vw, 104px);
  }
  .hero-title .thin { -webkit-text-stroke: 1.5px var(--bone); color: transparent; }
  .hero-copy p.lede { color: var(--muted); font-size: clamp(15px, 1.4vw, 17px); max-width: 44ch; margin: 18px 0 26px; }
  .hero-cta { display: flex; flex-wrap: wrap; gap: 12px; }
  .hero-facts { display: flex; gap: 26px; margin-top: 30px; padding-top: 22px; border-top: 1px solid var(--hair); }
  .hero-facts div { display: flex; flex-direction: column; gap: 2px; }
  .hero-facts .n { font-family: var(--f-mono); font-size: 22px; font-weight: 700; color: var(--bone); font-variant-numeric: tabular-nums; }
  .hero-facts .l { font-family: var(--f-mono); font-size: 10.5px; letter-spacing: .12em; text-transform: uppercase; color: var(--faint); }

  /* fanned stack of covers */
  .hero-stack { position: relative; height: clamp(320px, 40vw, 460px); }
  .hero-stack .cov {
    position: absolute; top: 50%; left: 50%; width: clamp(180px, 22vw, 250px); aspect-ratio: 2/3;
    border-radius: var(--radius); overflow: hidden; border: 1px solid var(--hair);
    box-shadow: 0 30px 60px -30px rgba(0,0,0,.95); background: var(--ink-2);
  }
  .hero-stack .cov img { width: 100%; height: 100%; object-fit: cover; }
  .hero-stack .cov:nth-child(1) { transform: translate(-50%,-50%) rotate(-9deg) translateX(-58%); z-index: 1; filter: brightness(.8); }
  .hero-stack .cov:nth-child(2) { transform: translate(-50%,-50%) rotate(5deg) translateX(52%); z-index: 2; filter: brightness(.9); }
  .hero-stack .cov:nth-child(3) { transform: translate(-50%,-50%) rotate(-2deg); z-index: 3; }
  .hero-stack .tag {
    position: absolute; z-index: 5; top: 8%; right: 4%;
    background: var(--gold); color: #1a1206; font-family: var(--f-mono); font-weight: 700;
    font-size: 11px; letter-spacing: .08em; text-transform: uppercase; padding: 6px 10px; border-radius: 3px;
    transform: rotate(6deg); box-shadow: 0 8px 20px -8px rgba(0,0,0,.8);
  }
  @media (prefers-reduced-motion: no-preference) {
    .hero-stack .cov { transition: transform .5s cubic-bezier(.2,.7,.2,1); }
    .hero:hover .hero-stack .cov:nth-child(1) { transform: translate(-50%,-50%) rotate(-11deg) translateX(-66%); }
    .hero:hover .hero-stack .cov:nth-child(2) { transform: translate(-50%,-50%) rotate(7deg) translateX(60%); }
  }
  @media (max-width: 860px) {
    .hero-grid { grid-template-columns: 1fr; }
    .hero-stack { order: -1; height: clamp(300px, 60vw, 380px); }
    .hero-facts { gap: 18px; }
  }
</style>

<section class="hero">
  <div class="wrap hero-grid">
    <div class="hero-copy">
      {%- if section.settings.eyebrow != blank -%}<span class="eyebrow">{{ section.settings.eyebrow }}</span>{%- endif -%}
      <h1 class="hero-title">{{ section.settings.title }}</h1>
      {%- if section.settings.text != blank -%}<p class="lede">{{ section.settings.text }}</p>{%- endif -%}
      <div class="hero-cta">
        {%- if section.settings.cta_label != blank -%}<a class="btn btn--primary" href="{{ section.settings.cta_link }}">{{ section.settings.cta_label }}</a>{%- endif -%}
        {%- if section.settings.cta2_label != blank -%}<a class="btn btn--ghost" href="{{ section.settings.cta2_link }}">{{ section.settings.cta2_label }}</a>{%- endif -%}
      </div>
      <div class="hero-facts">
        <div><span class="n">{{ collections.size }}+</span><span class="l">Collections</span></div>
        <div><span class="n">{{ section.settings.stat_variants }}</span><span class="l">Variant covers</span></div>
        <div><span class="n">{{ section.settings.stat_artists }}</span><span class="l">Artists</span></div>
      </div>
    </div>

    <div class="hero-stack">
      <span class="tag">{{ section.settings.stack_tag | default: 'Out now' }}</span>
      {%- if coll != empty and coll.products.size > 0 -%}
        {%- for product in coll.products limit: 3 -%}
          <div class="cov">
            {%- if product.featured_media -%}
              <img src="{{ product.featured_media | image_url: width: 500 }}" alt="{{ product.title | escape }}" loading="eager" width="250" height="375">
            {%- else -%}{{ product | placeholder_svg_tag }}{%- endif -%}
          </div>
        {%- endfor -%}
      {%- else -%}
        {%- for i in (1..3) -%}<div class="cov">{{ 'image' | placeholder_svg_tag }}</div>{%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "New drop · Issue 02 out now" },
    { "type": "text", "id": "title", "label": "Headline", "default": "Variant covers, not vanilla." },
    { "type": "textarea", "id": "text", "label": "Text", "default": "Independent comics with a shelf full of covers, prints, digitals and collectibles. Pick your cover. Chase the exclusives." },
    { "type": "text", "id": "cta_label", "label": "Primary button", "default": "Shop the drop" },
    { "type": "url", "id": "cta_link", "label": "Primary link" },
    { "type": "text", "id": "cta2_label", "label": "Secondary button", "default": "Browse series" },
    { "type": "url", "id": "cta2_link", "label": "Secondary link" },
    { "type": "header", "content": "Cover stack" },
    { "type": "collection", "id": "collection", "label": "Featured collection (newest 3 covers)" },
    { "type": "text", "id": "stack_tag", "label": "Sticker text", "default": "Out now" },
    { "type": "header", "content": "Stats" },
    { "type": "text", "id": "stat_variants", "label": "Variant count", "default": "400+" },
    { "type": "text", "id": "stat_artists", "label": "Artist count", "default": "20+" }
  ],
  "presets": [{ "name": "Hero" }]
}
{% endschema %}
