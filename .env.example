# ─── Shopify Admin API ────────────────────────────────────────────────────────
# Your store's myshopify.com domain (no protocol, no trailing slash).
SHOPIFY_STORE_DOMAIN=yourstore.myshopify.com

# Pin to the latest stable Admin API version.
# https://shopify.dev/docs/api/admin-graphql
SHOPIFY_API_VERSION=2026-07

# ─── Shopify auth: pick ONE of the two methods below ──────────────────────────
#
# METHOD 1 (recommended) — Dev Dashboard app, client-credentials grant.
# Legacy custom apps (shpat_ tokens) can no longer be created as of 2026-01-01,
# so new setups use this. Create the app at https://dev.shopify.com, install it
# on your store, then copy its Client ID + Client secret here. The server
# exchanges these for a short-lived access token and refreshes it automatically.
# The app and store must belong to the same Shopify organization.
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=
#
# METHOD 2 (legacy) — a static Admin API token from a custom app created BEFORE
# 2026-01-01. Leave CLIENT_ID/SECRET blank and set this instead. NEVER commit it.
# SHOPIFY_ACCESS_TOKEN=shpat_xxx

# ─── MCP endpoint protection (both layers) ────────────────────────────────────
# Layer 1: secret path segment. MCP is served at /mcp/{MCP_PATH_SECRET}.
# Use 32+ random chars, e.g. `openssl rand -hex 24`.
MCP_PATH_SECRET=change-me-to-a-long-random-string-32-plus-chars

# Layer 2 (optional): bearer token. When set, requests must send
# `Authorization: Bearer {MCP_AUTH_TOKEN}`. Leave blank to disable layer 2.
MCP_AUTH_TOKEN=

# ─── Server behaviour ─────────────────────────────────────────────────────────
# Register write/mutation tools only when this is exactly "true".
# Requires the write_* access scopes on the app (see README).
ENABLE_WRITES=true

PORT=3000
LOG_LEVEL=info

# ─── Cloudflare Tunnel (docker-compose only) ──────────────────────────────────
# Token for the `cloudflared` service. Not read by the MCP server itself.
TUNNEL_TOKEN=
