{
  "name": "shopify-admin-mcp",
  "version": "1.0.0",
  "description": "Self-hosted MCP server exposing the Shopify Admin GraphQL API over Streamable HTTP.",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "shopify-admin-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "express": "^4.21.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.5",
    "typescript": "^5.7.3"
  }
}
